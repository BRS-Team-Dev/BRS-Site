# Copy to .env (at project root) and fill in real values.
# This file is the ONLY source of credentials for the PHP backend.
# Never commit a real .env — it's gitignored.

# Environment label: local | dev | prod  (drives runtime branching)
BRS_ENV=local

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=builtrightstudio_cms
DB_USER=root
DB_PASS=

# --- Auth / JWT ---
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-to-a-64-char-random-hex-string
JWT_TTL=28800

# --- App ---
# Public-facing base URL (used in unsubscribe links, etc.). NO trailing slash.
BASE_URL=http://localhost/builtrightstudio
UPLOAD_MAX_MB=10
